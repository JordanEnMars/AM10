    "# Part A\n",
    "data=np.loadtxt(\"AM10-HW-05-US-cases-timeseries.txt\")\n",
    "time=data[:,0]\n",
    "cases=data[:,1]\n",
    "dx=1\n",
    "def central_diff(cases, dx):   \n",
    "    nx = len(cases)\n",
    "    d1_cent=np.zeros(nx)\n",
    "    for n in range (1, nx-1):\n",
    "        d1_cent[n] = (cases[n+1] - cases[n-1]) / (2.0 * dx)\n",
    "            \n",
    "    # Improve end points by first-order extrapolation\n",
    "    d1_cent[0] = 2 * d1_cent[1] - d1_cent[2]\n",
    "    d1_cent[nx - 1] = 2 * d1_cent[nx - 2] - d1_cent[nx - 3]\n",
    "\n",
    "    return d1_cent\n",
    "numerical_deriv=central_diff(cases,dx)\n",
    "\n",
    "# Part B\n",
    "t=np.arange(1,70.1,1)\n",
    "cprime=(10000)*((0.174*t-0.1739826*t+1))**(9999)*(0.174-0.1739826)\n",
    "\n",
    "print('Part C')\n",
    "fig1, ax1 = plt.subplots(figsize=(10, 6))\n",
    "ax1.set_xlabel('Time (days)')\n",
    "ax1.set_ylabel('Cases per day')\n",
    "ax1.plot(time, numerical_deriv , 'o',label='Numerical Derivative from Data')\n",
    "ax1.plot(t, cprime, '-', label='Analytical Derivative from Model')\n",
    "ax1.legend()\n",
    "ax1.set_title(\"Growth of Daily Cases\")\n",
    "plt.show(fig1)\n",
    "\n",
    "\n"
   ]
