   "source": [
    "# Part A\n",
    "def three_point_diff(fx, dx): \n",
    "    nx = len(fx)\n",
    "    d2fx=np.zeros(nx)\n",
    "    for n in range (1, nx-1):\n",
    "        d2fx[n] = (fx[n+1]-(2*fx[n]) + fx[n-1]) / ((dx)**2)\n",
    "            \n",
    "    # Improve end points by first-order extrapolation\n",
    "    d2fx[0] = 2 * d2fx[1] - d2fx[2]\n",
    "    d2fx[nx - 1] = 2 * d2fx[nx - 2] - d2fx[nx - 3]\n",
    "\n",
    "    return d2fx\n",
    "# Part B\n",
    "dx=0.5\n",
    "x=np.arange(0,10.1,dx)\n",
    "fofx=1/(np.exp(5-x)+1)\n",
    "\n",
    "d2fx_deriv=three_point_diff(fofx,dx)\n",
    "first_deriv=central_diff(fofx,dx)\n",
    "second_deriv=central_diff(first_deriv,dx)\n",
    "\n",
    "def true_deriv(x,u):\n",
    "    z = -1*(np.exp(x) - np.exp(u))*np.exp(x+u)/((np.exp(x) + np.exp(u))**3)\n",
    "    return z\n",
    "\n",
    "print(\"Part C\")\n",
    "fig1, ax1 = plt.subplots(figsize=(10, 6))\n",
    "ax1.set_xlabel('X')\n",
    "ax1.set_ylabel('Second Derivative of f(x)')\n",
    "ax1.plot(x,d2fx_deriv , 'o',label='using three_point_diff once')\n",
    "ax1.plot(x,second_deriv, 'd', label='using central_diff twice')\n",
    "ax1.plot(x,true_deriv(x,5),'k--',label=\"true derivative\")\n",
    "ax1.legend()\n",
    "plt.show(fig1)\n"
   ]
