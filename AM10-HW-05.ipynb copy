    "# Define constants\n",
    "mass = 5.0\n",
    "g = 10.0\n",
    "gam0 = 1.0\n",
    "k= 0.5\n",
    "\n",
    "# Define variables\n",
    "tmax = 10\n",
    "nt = 10000\n",
    "t = np.linspace(0, tmax, nt)\n",
    "dt = t[1]-t[0]\n",
    "dt2 = dt**2\n",
    "\n",
    "# Initialize variables\n",
    "gamma=np.zeros(nt)\n",
    "x = np.zeros(nt)\n",
    "v = np.zeros(nt)\n",
    "a = np.zeros(nt)\n",
    "\n",
    "# Define initial conditions\n",
    "x[0] = 50\n",
    "v[0] = 0.0\n",
    "gamma[0]=gam0*np.exp(-k*x[0])\n",
    "# Loop for the time propagation of position, velocity, acceleration\n",
    "for n in range(nt-1):\n",
    "    gamma[n]= gam0*np.exp(-k*x[n])\n",
    "    # acceleration\n",
    "    a[n] = -g + 0.5 * (gamma[n]/mass) * (v[n])**2\n",
    "    # position\n",
    "    x[n+1] = x[n] + v[n] * dt + 0.5 * a[n] * dt2\n",
    "    # velocity\n",
    "    v[n+1] = (x[n+1] - x[n]) / dt\n",
    "\n",
    "# Plot results\n",
    "plt.plot(t, x, 'g')\n",
    "plt.ylabel('position')\n",
    "plt.xlabel('time')\n",
    "plt.title('Position vs Time')\n",
    "plt.show()\n",
    "plt.plot(t, v, 'g')\n",
    "plt.ylabel('velocity')\n",
    "plt.xlabel('time')\n",
    "plt.title('Velocity vs Time')\n",
    "plt.show()\n",
    "plt.plot(t, a, 'g')\n",
    "plt.ylabel('acceleration')\n",
    "plt.xlabel('time')\n",
    "plt.title(\"Acceleration vs Time\")\n",
    "plt.show()\n"
   ]
